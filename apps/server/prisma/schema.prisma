// Taskettle Prisma schema.
// Dev uses SQLite. For production, switch provider to "postgresql"
// and update DATABASE_URL — no model changes required.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NOTE: SQLite does not support Prisma enums, so these are stored as String.
// Allowed values are enforced in TypeScript (src/types) and Zod schemas:
//   Role             = 'OWNER' | 'MEMBER'
//   TaskStatus       = 'TODO' | 'DOING' | 'DONE'
//   TaskPriority     = 'LOW' | 'MEDIUM' | 'HIGH' | 'URGENT'
//   InviteStatus     = 'PENDING' | 'ACCEPTED' | 'EXPIRED'
//   NotificationType = 'DUE_SOON' | 'OVERDUE' | 'DEBT_DUE_SOON' | 'DEBT_OVERDUE'
//   InventoryStatus  = 'IN_STOCK' | 'LOW_STOCK' | 'OUT_OF_STOCK'
//   ShoppingItemStatus = 'PENDING' | 'PURCHASED'
//   WalletAccountType  = 'CASH' | 'BANK' | 'CARD' | 'SAVINGS' | 'OTHER'
//   WalletCategoryType = 'INCOME' | 'EXPENSE'
//   TransactionType    = 'INCOME' | 'EXPENSE' | 'TRANSFER' | 'DEBT_PAYMENT'
//   BudgetPeriod       = 'WEEKLY' | 'MONTHLY' | 'CUSTOM'
//   DebtStatus         = 'OPEN' | 'PARTIALLY_PAID' | 'PAID' | 'CANCELLED'
//   HomeAssetCategory  = 'APPLIANCE' | 'ELECTRONICS' | 'FURNITURE' | 'POWER_TOOL' | 'OTHER'
//   RecurringExpenseCategory = 'UTILITY' | 'SUBSCRIPTION'
//   RecurringExpenseFrequency = 'MONTHLY' | 'QUARTERLY' | 'ANNUAL'
//   MaintenanceFrequency = 'WEEKLY' | 'MONTHLY' | 'QUARTERLY' | 'ANNUAL' | 'CUSTOM'
//   BusinessType         = 'PRINTING_3D' | 'GENERAL'
// Money is stored as integer minor units (e.g. cents) plus an ISO currency code.
// Switching to Postgres later, these can be promoted back to real enums.

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  avatarColor  String   @default("#8fa998")
  createdAt    DateTime @default(now())

  memberships   Membership[]
  createdTasks  Task[]         @relation("TaskCreatedBy")
  assignedTasks Task[]         @relation("TaskAssignee")
  sentInvites   Invite[]       @relation("InviteSentBy")
  notifications Notification[]

  createdInventoryItems  InventoryItem[]    @relation("InventoryCreatedBy")
  addedShoppingItems     ShoppingListItem[] @relation("ShoppingAddedBy")
  purchasedShoppingItems ShoppingListItem[] @relation("ShoppingPurchasedBy")

  ownedWalletAccounts  WalletAccount[]     @relation("WalletAccountOwner")
  createdTransactions  WalletTransaction[] @relation("TransactionCreatedBy")
  createdBudgets       Budget[]            @relation("BudgetCreatedBy")
  lentDebts            Debt[]              @relation("DebtLender")
  borrowedDebts        Debt[]              @relation("DebtBorrower")
  createdDebts         Debt[]              @relation("DebtCreatedBy")
  paidDebtPayments     DebtPayment[]       @relation("DebtPaymentPaidBy")
  receivedDebtPayments DebtPayment[]       @relation("DebtPaymentPaidTo")

  createdHomeAssets        HomeAsset[]          @relation("HomeAssetCreatedBy")
  createdRecurringExpenses RecurringExpense[]   @relation("RecurringExpenseCreatedBy")
  createdVehicles          Vehicle[]            @relation("VehicleCreatedBy")
  createdMaintenanceSchedules MaintenanceSchedule[] @relation("MaintenanceScheduleCreatedBy")

  createdBusinesses        Business[]           @relation("BusinessCreatedBy")
  createdProducts          Product[]            @relation("ProductCreatedBy")
}

model Circle {
  id        String   @id @default(cuid())
  name      String
  icon      String   @default("family_history")
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())

  memberships    Membership[]
  tasks          Task[]
  invites        Invite[]
  inventoryItems InventoryItem[]
  shoppingList   ShoppingListItem[]

  walletAccounts     WalletAccount[]
  walletCategories   WalletCategory[]
  walletTransactions WalletTransaction[]
  budgets            Budget[]
  debts              Debt[]

  homeAssets         HomeAsset[]
  recurringExpenses  RecurringExpense[]
  vehicles           Vehicle[]
  maintenanceSchedules MaintenanceSchedule[]
  businesses         Business[]
}

model Membership {
  id       String   @id @default(cuid())
  userId   String
  circleId String
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@unique([userId, circleId])
  @@index([circleId])
  @@index([userId])
}

model Invite {
  id          String       @id @default(cuid())
  circleId    String
  email       String
  token       String   @unique @default(cuid())
  status      String   @default("PENDING")
  invitedById String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  circle    Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  invitedBy User   @relation("InviteSentBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([circleId])
  @@index([email])
}

model Task {
  id          String     @id @default(cuid())
  circleId    String
  title       String
  description String?
  status      String     @default("TODO")
  priority    String     @default("MEDIUM")
  category    String?
  assigneeId  String?
  dueDate     DateTime?
  position    Float      @default(1024)
  createdById String
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  circle    Circle         @relation(fields: [circleId], references: [id], onDelete: Cascade)
  assignee  User?          @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy User           @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@index([circleId, status, position])
  @@index([dueDate])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  taskId    String?
  debtId    String?
  type      String   @default("DUE_SOON")
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  debt Debt? @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId, type])
  @@unique([userId, debtId, type])
  @@index([userId, read])
}

model InventoryItem {
  id               String   @id @default(cuid())
  circleId         String
  name             String
  description      String?
  category         String?
  quantity         Float    @default(0)
  unit             String?
  minimumThreshold Float    @default(0)
  location         String?
  notes            String?
  status           String   @default("IN_STOCK")
  unitPriceMinor   Int?
  businessId       String?
  createdById      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  circle    Circle    @relation(fields: [circleId], references: [id], onDelete: Cascade)
  business  Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  createdBy User      @relation("InventoryCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  shoppingListItems ShoppingListItem[]

  @@index([circleId, status])
  @@index([circleId, category])
  @@index([circleId, businessId])
}

model ShoppingListItem {
  id              String    @id @default(cuid())
  circleId        String
  inventoryItemId String?
  name            String
  quantityNeeded  Float     @default(1)
  unit            String?
  status          String    @default("PENDING")
  addedById       String
  purchasedById   String?
  purchasedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  circle        Circle         @relation(fields: [circleId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  addedBy       User           @relation("ShoppingAddedBy", fields: [addedById], references: [id], onDelete: Cascade)
  purchasedBy   User?          @relation("ShoppingPurchasedBy", fields: [purchasedById], references: [id], onDelete: SetNull)

  @@index([circleId, status])
}

model WalletAccount {
  id        String   @id @default(cuid())
  circleId  String
  name      String
  type      String   @default("CASH")
  currency  String   @default("USD")
  ownerId   String?
  archivedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  circle       Circle              @relation(fields: [circleId], references: [id], onDelete: Cascade)
  owner        User?               @relation("WalletAccountOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  transactions WalletTransaction[]
  defaultForBusinesses Business[]  @relation("BusinessDefaultAccount")

  @@index([circleId])
}

model WalletCategory {
  id        String   @id @default(cuid())
  circleId  String
  name      String
  type      String   @default("EXPENSE")
  color     String   @default("#8fa998")
  icon      String   @default("payments")
  createdAt DateTime @default(now())

  circle       Circle              @relation(fields: [circleId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
  budgets      Budget[]

  @@unique([circleId, name, type])
  @@index([circleId, type])
}

model WalletTransaction {
  id              String   @id @default(cuid())
  circleId        String
  accountId       String
  type            String   @default("EXPENSE")
  amountMinor     Int
  currency        String   @default("USD")
  categoryId      String?
  note            String?
  payee           String?
  transactionDate DateTime @default(now())
  createdById     String
  debtId          String?
  businessId      String?
  productId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  circle    Circle          @relation(fields: [circleId], references: [id], onDelete: Cascade)
  account   WalletAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category  WalletCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy User            @relation("TransactionCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  debt      Debt?           @relation(fields: [debtId], references: [id], onDelete: SetNull)
  business  Business?       @relation(fields: [businessId], references: [id], onDelete: SetNull)
  product   Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  payment   DebtPayment?

  @@index([circleId, transactionDate])
  @@index([circleId, accountId])
  @@index([circleId, categoryId])
  @@index([circleId, businessId])
}

model Budget {
  id          String    @id @default(cuid())
  circleId    String
  name        String
  categoryId  String?
  amountMinor Int
  currency    String    @default("USD")
  period      String    @default("MONTHLY")
  startsAt    DateTime  @default(now())
  endsAt      DateTime?
  createdById String
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  circle    Circle          @relation(fields: [circleId], references: [id], onDelete: Cascade)
  category  WalletCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy User            @relation("BudgetCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([circleId])
}

model Debt {
  id          String    @id @default(cuid())
  circleId    String
  lenderId    String
  borrowerId  String
  amountMinor Int
  currency    String    @default("USD")
  reason      String?
  dueDate     DateTime?
  status      String    @default("OPEN")
  createdById String
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  circle       Circle              @relation(fields: [circleId], references: [id], onDelete: Cascade)
  lender       User                @relation("DebtLender", fields: [lenderId], references: [id], onDelete: Cascade)
  borrower     User                @relation("DebtBorrower", fields: [borrowerId], references: [id], onDelete: Cascade)
  createdBy    User                @relation("DebtCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  payments     DebtPayment[]
  transactions WalletTransaction[]
  notifications Notification[]

  @@index([circleId, status])
  @@index([lenderId])
  @@index([borrowerId])
}

model DebtPayment {
  id                  String   @id @default(cuid())
  debtId              String
  amountMinor         Int
  currency            String   @default("USD")
  paidById            String
  paidToId            String
  paidAt              DateTime @default(now())
  walletTransactionId String?  @unique
  createdAt           DateTime @default(now())

  debt              Debt               @relation(fields: [debtId], references: [id], onDelete: Cascade)
  paidBy            User               @relation("DebtPaymentPaidBy", fields: [paidById], references: [id], onDelete: Cascade)
  paidTo            User               @relation("DebtPaymentPaidTo", fields: [paidToId], references: [id], onDelete: Cascade)
  walletTransaction WalletTransaction? @relation(fields: [walletTransactionId], references: [id], onDelete: SetNull)

  @@index([debtId])
}

// Phase 2: Household Management

model HomeAsset {
  id                  String   @id @default(cuid())
  circleId            String
  name                String
  category            String   @default("OTHER")
  purchaseDate        DateTime?
  warrantyExpiration  DateTime?
  serialNumber        String?
  receiptPhotoUrls    String?  // JSON array of URLs stored as string
  currentValue        Int?     // Optional; in minor units if tracking value
  notes               String?
  createdById         String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  circle    Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  createdBy User   @relation("HomeAssetCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([circleId, category])
  @@index([circleId, warrantyExpiration])
}

model RecurringExpense {
  id           String   @id @default(cuid())
  circleId     String
  name         String
  category     String   @default("UTILITY")  // UTILITY | SUBSCRIPTION
  amountMinor  Int
  currency     String   @default("USD")
  dueDate      Int?     // Day of month (1-31) or null for flexible
  frequency    String   @default("MONTHLY")  // MONTHLY | QUARTERLY | ANNUAL
  autoPay      Boolean  @default(false)
  notes        String?
  lastOccurred DateTime?
  nextDue      DateTime?
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  circle    Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  createdBy User   @relation("RecurringExpenseCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([circleId, category])
  @@index([circleId, nextDue])
}

model Vehicle {
  id                  String   @id @default(cuid())
  circleId            String
  name                String
  model               String?
  plateNumber         String?
  registrationExpiry  DateTime?
  insuranceExpiry     DateTime?
  notes               String?
  createdById         String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  circle    Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  createdBy User   @relation("VehicleCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([circleId])
  @@index([registrationExpiry])
  @@index([insuranceExpiry])
}

model MaintenanceSchedule {
  id           String   @id @default(cuid())
  circleId     String
  title        String
  description  String?
  frequency    String   @default("MONTHLY")  // WEEKLY | MONTHLY | QUARTERLY | ANNUAL | CUSTOM
  nextDueDate  DateTime
  assigneeId   String?
  lastTaskId   String?  // Reference to last created Task (for deduplication)
  notes        String?
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  circle    Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  createdBy User   @relation("MaintenanceScheduleCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([circleId, nextDueDate])
}

// --- Business Management (multi-business; first type: 3D printing) ---
// BusinessType = 'PRINTING_3D' | 'GENERAL'
// Money is stored as integer minor units (e.g. centavos) plus an ISO currency code.
model Business {
  id        String   @id @default(cuid())
  circleId  String
  name      String
  type      String   @default("PRINTING_3D") // PRINTING_3D | GENERAL
  currency  String   @default("PHP")
  defaultAccountId String?

  // Calculator default settings (per business; all optional)
  printerPowerW             Int?   // watts
  printerPriceMinor         Int?   // purchase price in minor units
  printerLifespanHr         Int?   // expected machine life in hours
  electricityRatePerKwhMinor Int?  // grid rate in minor units per kWh
  laborRatePerHrMinor       Int?   // labor rate in minor units per hour
  failurePct                Float? // default failure/spoilage rate (0-100)
  markupPct                 Float? // default profit markup (0-100)

  createdById String
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  circle         Circle             @relation(fields: [circleId], references: [id], onDelete: Cascade)
  createdBy      User               @relation("BusinessCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  defaultAccount WalletAccount?     @relation("BusinessDefaultAccount", fields: [defaultAccountId], references: [id], onDelete: SetNull)
  products       Product[]
  transactions   WalletTransaction[]
  inventoryItems InventoryItem[]

  @@index([circleId])
}

// A saved cost-calculator output that can be reused and converted into a sale.
model Product {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  notes       String?
  currency    String   @default("PHP")

  // Raw calculator inputs (filament rows + parameters) for re-editing.
  inputs      String   // JSON string

  // Computed breakdown (minor units).
  materialCostMinor    Int   @default(0)
  electricityCostMinor Int   @default(0)
  wearCostMinor        Int   @default(0)
  laborCostMinor       Int   @default(0)
  subtotalMinor        Int   @default(0)
  failurePct           Float @default(0)
  markupPct            Float @default(0)
  finalPriceMinor      Int   @default(0)

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business     Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy    User                @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@index([businessId])
}
