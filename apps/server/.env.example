# Server config
NODE_ENV=development
PORT=4000

# Comma-separated allowlist of web origins for CORS
CORS_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Database (SQLite for dev; swap provider+URL for Postgres in prod)
DATABASE_URL="file:./dev.db"

# Reminder scanner: cron expression (default: every 15 minutes)
REMINDER_CRON=*/15 * * * *
# How many hours ahead counts as "due soon"
REMINDER_DUE_SOON_HOURS=24
